<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pointbank.securities.product.mapper.SecuritiesProductMapper">
    <resultMap id="productResultMap" type="com.pointbank.securities.product.domain.SecuritiesProduct">
        <id property="id" column="id"/>
        <result property="stockCode" column="stock_code"/>
        <result property="stockName" column="stock_name"/>
        <result property="market" column="market"/>
        <result property="sector" column="sector"/>
        <result property="status" column="status" javaType="com.pointbank.securities.product.domain.ProductStatus"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="productColumns">
        id, stock_code, stock_name, market, sector, status, created_at, updated_at
    </sql>

    <select id="findByStockCode" resultMap="productResultMap">
        SELECT <include refid="productColumns"/>
        FROM securities_products
        WHERE stock_code = #{stockCode}
    </select>

    <select id="existsActiveByStockCode" resultType="boolean">
        SELECT COUNT(*) &gt; 0
        FROM securities_products
        WHERE stock_code = #{stockCode}
          AND status = 'ACTIVE'
    </select>

    <select id="findActiveProducts" resultMap="productResultMap">
        SELECT <include refid="productColumns"/>
        FROM securities_products
        WHERE status = 'ACTIVE'
        ORDER BY market ASC, stock_code ASC
    </select>
</mapper>
