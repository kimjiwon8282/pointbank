<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pointbank.banking.account.mapper.AccountMapper">

    <resultMap id="accountResultMap" type="com.pointbank.banking.account.domain.Account">
        <id property="id" column="id"/>
        <result property="memberId" column="member_id"/>
        <result property="accountNumber" column="account_number"/>
        <result property="accountPasswordHash" column="account_password_hash"/>
        <result property="balance" column="balance"/>
        <result property="status" column="status" javaType="com.pointbank.banking.account.domain.AccountStatus"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="accountColumns">
        id, member_id, account_number, account_password_hash,
        balance, status, created_at, updated_at
    </sql>

    <select id="existsByMemberId" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM accounts
        WHERE member_id = #{memberId}
    </select>

    <select id="findByMemberId" resultMap="accountResultMap">
        SELECT <include refid="accountColumns"/>
        FROM accounts
        WHERE member_id = #{memberId}
    </select>

    <select id="findByMemberIdForUpdate" resultMap="accountResultMap">
        SELECT <include refid="accountColumns"/>
        FROM accounts
        WHERE member_id = #{memberId}
        FOR UPDATE
    </select>

    <select id="findByAccountNumber" resultMap="accountResultMap">
        SELECT <include refid="accountColumns"/>
        FROM accounts
        WHERE account_number = #{accountNumber}
    </select>

    <select id="findById" resultMap="accountResultMap">
        SELECT <include refid="accountColumns"/>
        FROM accounts
        WHERE id = #{accountId}
    </select>

    <select id="findAllByIdsForUpdate" resultMap="accountResultMap">
        SELECT <include refid="accountColumns"/>
        FROM accounts
        WHERE id IN
        <foreach collection="accountIds" item="accountId" open="(" separator="," close=")">
            #{accountId}
        </foreach>
        ORDER BY id ASC
        FOR UPDATE
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO accounts (
            member_id, account_number, account_password_hash, balance, status
        ) VALUES (
            #{memberId}, #{accountNumber}, #{accountPasswordHash}, #{balance}, #{status}
        )
    </insert>

    <update id="updateBalance">
        UPDATE accounts
        SET balance = #{balance}
        WHERE id = #{accountId}
    </update>
</mapper>
