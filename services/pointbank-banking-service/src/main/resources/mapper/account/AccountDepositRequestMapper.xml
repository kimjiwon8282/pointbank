<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pointbank.banking.account.mapper.AccountDepositRequestMapper">

    <resultMap id="accountDepositRequestResultMap"
               type="com.pointbank.banking.account.domain.AccountDepositRequestRecord">
        <id property="id" column="id"/>
        <result property="requestNo" column="request_no"/>
        <result property="memberId" column="member_id"/>
        <result property="accountId" column="account_id"/>
        <result property="amount" column="amount"/>
        <result property="balanceAfter" column="balance_after"/>
        <result property="status" column="status"
                javaType="com.pointbank.banking.account.domain.AccountDepositStatus"/>
        <result property="failureReason" column="failure_reason"/>
        <result property="createdAt" column="created_at"/>
        <result property="completedAt" column="completed_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="accountDepositRequestColumns">
        id, request_no, member_id, account_id, amount, balance_after, status,
        failure_reason, created_at, completed_at, updated_at
    </sql>

    <insert id="insertRequested" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO account_deposit_requests (
            request_no, member_id, amount, status
        ) VALUES (
            #{requestNo}, #{memberId}, #{amount}, #{status}
        )
    </insert>

    <select id="findByRequestNo" resultMap="accountDepositRequestResultMap">
        SELECT <include refid="accountDepositRequestColumns"/>
        FROM account_deposit_requests
        WHERE request_no = #{requestNo}
    </select>

    <update id="complete">
        UPDATE account_deposit_requests
        SET account_id = #{accountId},
            balance_after = #{balanceAfter},
            status = 'COMPLETED',
            completed_at = #{completedAt}
        WHERE id = #{id}
          AND status = 'REQUESTED'
    </update>
</mapper>
