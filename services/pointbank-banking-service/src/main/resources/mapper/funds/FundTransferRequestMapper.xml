<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pointbank.banking.funds.mapper.FundTransferRequestMapper">

    <resultMap id="fundTransferRequestResultMap"
               type="com.pointbank.banking.funds.domain.FundTransferRequest">
        <id property="id" column="id"/>
        <result property="requestNo" column="request_no"/>
        <result property="memberId" column="member_id"/>
        <result property="sourceType" column="source_type"
                javaType="com.pointbank.banking.funds.domain.FundAccountType"/>
        <result property="targetType" column="target_type"
                javaType="com.pointbank.banking.funds.domain.FundAccountType"/>
        <result property="sourceAccountId" column="source_account_id"/>
        <result property="targetAccountId" column="target_account_id"/>
        <result property="amount" column="amount"/>
        <result property="bankingBalanceAfter" column="banking_balance_after"/>
        <result property="status" column="status"
                javaType="com.pointbank.banking.funds.domain.FundTransferStatus"/>
        <result property="failureReason" column="failure_reason"/>
        <result property="createdAt" column="created_at"/>
        <result property="completedAt" column="completed_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="fundTransferRequestColumns">
        id, request_no, member_id, source_type, target_type, source_account_id,
        target_account_id, amount, banking_balance_after, status, failure_reason,
        created_at, completed_at, updated_at
    </sql>

    <insert id="insertRequested" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO fund_transfer_requests (
            request_no, member_id, source_type, target_type, amount, status
        ) VALUES (
            #{requestNo}, #{memberId}, #{sourceType}, #{targetType}, #{amount}, #{status}
        )
    </insert>

    <select id="findByRequestNo" resultMap="fundTransferRequestResultMap">
        SELECT <include refid="fundTransferRequestColumns"/>
        FROM fund_transfer_requests
        WHERE request_no = #{requestNo}
    </select>

    <update id="complete">
        UPDATE fund_transfer_requests
        SET source_account_id = #{sourceAccountId},
            target_account_id = #{targetAccountId},
            banking_balance_after = #{bankingBalanceAfter},
            status = 'COMPLETED',
            completed_at = #{completedAt}
        WHERE id = #{id}
          AND status = 'REQUESTED'
    </update>
</mapper>
