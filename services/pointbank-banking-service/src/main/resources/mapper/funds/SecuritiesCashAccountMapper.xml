<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pointbank.banking.funds.mapper.SecuritiesCashAccountMapper">

    <resultMap id="securitiesCashAccountResultMap"
               type="com.pointbank.banking.funds.domain.SecuritiesCashAccount">
        <id property="id" column="id"/>
        <result property="memberId" column="member_id"/>
        <result property="cashBalance" column="cash_balance"/>
        <result property="reservedCash" column="reserved_cash"/>
        <result property="status" column="status"
                javaType="com.pointbank.banking.funds.domain.SecuritiesCashAccountStatus"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="securitiesCashAccountColumns">
        id, member_id, cash_balance, reserved_cash, status, created_at, updated_at
    </sql>

    <select id="findByMemberId" resultMap="securitiesCashAccountResultMap">
        SELECT <include refid="securitiesCashAccountColumns"/>
        FROM securities_cash_accounts
        WHERE member_id = #{memberId}
    </select>

    <select id="findByMemberIdForUpdate" resultMap="securitiesCashAccountResultMap">
        SELECT <include refid="securitiesCashAccountColumns"/>
        FROM securities_cash_accounts
        WHERE member_id = #{memberId}
        FOR UPDATE
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO securities_cash_accounts (
            member_id, cash_balance, reserved_cash, status
        ) VALUES (
            #{memberId}, #{cashBalance}, #{reservedCash}, #{status}
        )
    </insert>

    <update id="updateCashBalance">
        UPDATE securities_cash_accounts
        SET cash_balance = #{cashBalance}
        WHERE id = #{id}
    </update>
</mapper>
