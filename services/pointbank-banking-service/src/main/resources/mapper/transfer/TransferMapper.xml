<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pointbank.banking.transfer.mapper.TransferMapper">
    <resultMap id="transferResultMap" type="com.pointbank.banking.transfer.domain.Transfer">
        <id property="id" column="id"/>
        <result property="transferNo" column="transfer_no"/>
        <result property="requestNo" column="request_no"/>
        <result property="fromAccountId" column="from_account_id"/>
        <result property="toAccountId" column="to_account_id"/>
        <result property="fromMemberId" column="from_member_id"/>
        <result property="toMemberId" column="to_member_id"/>
        <result property="amount" column="amount"/>
        <result property="status" column="status" javaType="com.pointbank.banking.transfer.domain.TransferStatus"/>
        <result property="failureReason" column="failure_reason"/>
        <result property="createdAt" column="created_at"/>
        <result property="completedAt" column="completed_at"/>
    </resultMap>

    <sql id="transferColumns">
        id, transfer_no, request_no, from_account_id, to_account_id, from_member_id,
        to_member_id, amount, status, failure_reason, created_at, completed_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO transfers (
            transfer_no, request_no, from_account_id, to_account_id, from_member_id,
            to_member_id, amount, status, failure_reason, completed_at
        ) VALUES (
            #{transferNo}, #{requestNo}, #{fromAccountId}, #{toAccountId}, #{fromMemberId},
            #{toMemberId}, #{amount}, #{status}, #{failureReason}, #{completedAt}
        )
    </insert>

    <update id="complete">
        UPDATE transfers
        SET status = 'COMPLETED',
            completed_at = #{completedAt}
        WHERE id = #{id}
          AND status = 'REQUESTED'
    </update>

    <select id="findById" resultMap="transferResultMap">
        SELECT <include refid="transferColumns"/> FROM transfers WHERE id = #{id}
    </select>

    <select id="findByTransferNo" resultMap="transferResultMap">
        SELECT <include refid="transferColumns"/> FROM transfers WHERE transfer_no = #{transferNo}
    </select>

    <select id="findByRequestNo" resultMap="transferResultMap">
        SELECT <include refid="transferColumns"/> FROM transfers WHERE request_no = #{requestNo}
    </select>
</mapper>
